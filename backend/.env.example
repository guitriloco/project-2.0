# ==========================================
# Project 2.0 - Environment Configuration
# ==========================================

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=sqlite://./db.sqlite

# Xerebro AI
XEREBRO_MODE=development
XEREBRO_API_KEY=your-api-key-here

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
ENABLE_XEREBRO_VOICE=true
ENABLE_BIO_DIGITAL_SYNC=true
ENABLE_UNIVERSAL_UNIFICATION=true