const fs = require('fs');
const path = require('path');
const http = require('http');
const KernelSynthesizer = require('./kernel_synthesizer');

const YES_ENGINE_URL = 'http://localhost:8012';
const PROCESSED_EVENTS_FILE = path.join(__dirname, 'processed_nectar_events.json');

class NectarDrivenSynthesizer {
    constructor() {
        this.synthesizer = new KernelSynthesizer();
        this.processedEvents = this.loadProcessedEvents();
    }

    loadProcessedEvents() {
        if (fs.existsSync(PROCESSED_EVENTS_FILE)) {
            return JSON.parse(fs.readFileSync(PROCESSED_EVENTS_FILE, 'utf8'));
        }
        return [];
    }

    saveProcessedEvents() {
        fs.writeFileSync(PROCESSED_EVENTS_FILE, JSON.stringify(this.processedEvents, null, 2));
    }

    async getEvents() {
        return new Promise((resolve, reject) => {
            http.get(`${YES_ENGINE_URL}/nectar/events`, (res) => {
                let data = '';
                res.on('data', (chunk) => { data += chunk; });
                res.on('end', () => {
                    try {
                        resolve(JSON.parse(data));
                    } catch (e) {
                        reject(e);
                    }
                });
            }).on('error', (err) => {
                reject(err);
            });
        });
    }

    async monitor() {
        console.log('--- Nectar-Driven Evolutionary Synthesizer Active ---');
        setInterval(async () => {
            try {
                const data = await this.getEvents();
                const events = data.events;

                for (const event of events) {
                    const eventId = `${event.timestamp}_${event.yield_roi}`;
                    if (!this.processedEvents.includes(eventId)) {
                        console.log(`NEW ABSOLUTE NECTAR DETECTED: ROI ${event.yield_roi}`);
                        await this.processNectarEvent(event);
                        this.processedEvents.push(eventId);
                    }
                }
                this.saveProcessedEvents();
            } catch (error) {
                // Suppress log noise if YES engine is down
                if (!error.message.includes('ECONNREFUSED')) {
                    console.error('Error monitoring Nectar events:', error.message);
                }
            }
        }, 10000); // Check every 10 seconds for testing
    }

    async processNectarEvent(event) {
        console.log('Synthesizing evolutionary kernel based on high-performance Nectar signal...');
        
        const domain = 'YieldOptimization';
        const requirement = `Reinforce high-performance patterns found in Nectar signal with ROI ${event.yield_roi}. Mode used: ${event.mode}.`;
        
        const kernel = await this.synthesizer.synthesize(domain, requirement);
        this.synthesizer.saveKernel(kernel);
        
        console.log(`Evolutionary kernel ${kernel.kernelName} synthesized and deployed.`);
    }
}

const nectarSynthesizer = new NectarDrivenSynthesizer();
nectarSynthesizer.monitor();
